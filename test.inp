&GLOBAL
  RUN_TYPE GEO_OPT
&END GLOBAL

&FORCE_EVAL
  METHOD IPI
  &SUBSYS
    &CELL
      ABC 10.0 10.0 10.0
      PERIODIC NONE
    &END CELL
    &TOPOLOGY
      COORD_FILE_FORMAT xyz
      COORD_FILE_NAME ../Spicy/spicy/h.xyz
    &END TOPOLOGY
  &END SUBSYS
&END FORCE_EVAL

&MOTION
  &MD
    STEPS 1000
    TIMESTEP 0.25
    ENSEMBLE NVT
    TEMPERATURE 300
    &THERMOSTAT
      TYPE CSVR
      REGION MASSIVE
      &CSVR
        TIMECON 25
      &END CSVR
    &END THERMOSTAT
  &END MD
  &GEO_OPT
  &END GEO_OPT
  &DRIVER
    HOST myHost
    PORT 8421
    UNIX
    SLEEP_TIME 0.1
  &END DRIVER
  &PRINT
    &TRAJECTORY
      &EACH
        MD 10
      &END EACH
    &END TRAJECTORY
    &FORCES
      &EACH
        MD 1
      &END EACH
    &END FORCES
  &END PRINT
&END MOTION
